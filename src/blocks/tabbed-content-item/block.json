{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "humanmade/tabbed-content-item",
	"version": "0.2.0",
	"title": "Tabbed Content Item",
	"category": "design",
	"icon": "list-view",
	"parent": [ "humanmade/tabbed-content" ],
	"description": "A single tab inside a Tabbed Content block.",
	"keywords": [ "tab", "tabbed", "item" ],
	"textdomain": "hm-tabbed-content",
	"attributes": {
		"title": {
			"type": "string",
			"default": ""
		},
		"id": {
			"type": "integer"
		},
		"url": {
			"type": "string",
			"default": ""
		},
		"alt": {
			"type": "string",
			"default": ""
		},
		"thumbnailId": {
			"type": "integer"
		},
		"thumbnailUrl": {
			"type": "string",
			"default": ""
		},
		"thumbnailAlt": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"align": false,
		"html": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true,
			"link": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalFontFamily": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
